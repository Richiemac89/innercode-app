# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
# Settings → API → Project URL and anon/public key

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Copy this file to .env (not committed to git)
# 2. Replace the values above with your actual Supabase credentials
# 3. Restart your dev server after creating .env
